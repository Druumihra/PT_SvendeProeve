//API

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Users {
  name   String
  id     Int      @unique @id
  groups Groups[]
}

model Groups {
  id           Int   @id @unique @default(autoincrement())
  name         String @unique
  members Users? @relation(fields: [usersId], references: [id])
  usersId      Int?
  admins Int
  challenges  Challenges[]
}

model Challenges {
  name        String
  id          Int    @unique @id @default(autoincrement())
  description String
  group       Groups? @relation(fields: [groupsId], references: [id])
  groupsId    Int?
  active Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
