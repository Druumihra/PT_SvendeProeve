//API
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Users {
  name              String
  id                Int                @id @unique
  profilepicture    Bytes?
  groups            Groups[]
  challengesResults ChallengesResult[]
  admins            GroupAdmins[]
  votes             votes[]
  friends           Friends[]          @relation(name: "user")
  friendof          Friends[]          @relation(name: "friendof")
}

model Friends {
  accepted Boolean @default(false)
  user     Users?  @relation(name: "user", fields: [usersId], references: [id])
  usersId  Int     @id
  friendof Users?  @relation(name: "friendof", fields: [friendid], references: [id])
  friendid Int
}

model Groups {
  id         Int           @id @default(autoincrement())
  name       String        @unique
  members    Users?        @relation(fields: [usersId], references: [id])
  usersId    Int?
  admins     GroupAdmins[]
  challenges Challenges[]
}

model GroupAdmins {
  id       Int    @id @default(autoincrement())
  admin    Users  @relation(fields: [usersId], references: [id])
  group    Groups @relation(fields: [groupsId], references: [id])
  usersId  Int
  groupsId Int
}

model Challenges {
  name              String
  id                Int                @id @unique @default(autoincrement())
  description       String
  score             Int
  group             Groups?            @relation(fields: [groupsId], references: [id])
  groupsId          Int?
  active            Boolean
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  challengesResults ChallengesResult[]
  votes             votes[]
}

model votes {
  id           Int        @id @default(autoincrement())
  User         Users?     @relation(fields: [usersId], references: [id])
  Challenge    Challenges @relation(fields: [challengesId], references: [id])
  usersId      Int?
  challengesId Int
  vote         Boolean?
}

model ChallengesResult {
  User         Users      @relation(fields: [usersId], references: [id])
  proof        Bytes
  validated    Boolean    @default(false)
  date         DateTime   @default(now())
  Challenge    Challenges @relation(fields: [challengesId], references: [id])
  usersId      Int
  challengesId Int        @id
}
