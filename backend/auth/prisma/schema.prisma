//Auth

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"

}

datasource db {
  provider = "mysql"
}

model Users {
  name     String
  email    String     @unique
  id       Int        @id @unique @default(autoincrement())
  password String
  sessions Sessions[]
}

model Sessions {
  userId    Int
  sessionId Int   @id
  createdAt Int
  user      Users @relation(fields: [userId], references: [id])
}
